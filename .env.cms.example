# Development defaults belong in docker-compose.yml. Production values must be injected by the runtime.
DATABASE_URL=postgresql://pesaba:change-me@localhost:55432/pesaba_cms?schema=public
CMS_API_PORT=4400
CMS_WEB_ORIGIN=http://localhost:3000
CMS_SESSION_SECRET=replace-with-at-least-32-random-characters
CMS_S3_ENDPOINT=http://localhost:9000
CMS_S3_REGION=us-east-1
CMS_S3_BUCKET=pesaba-media
CMS_S3_ACCESS_KEY=replace-me
CMS_S3_SECRET_KEY=replace-me
CMS_S3_PUBLIC_URL=http://localhost:9000/pesaba-media
CMS_SMTP_HOST=
CMS_SMTP_PORT=587
CMS_SMTP_USER=
CMS_SMTP_PASS=
CMS_SMTP_FROM=
CMS_PLAUSIBLE_HOST=
CMS_PLAUSIBLE_DOMAIN=pesaba.com
CMS_PLAUSIBLE_API_KEY=
CMS_BOOTSTRAP_EMAIL=owner@example.com
CMS_BOOTSTRAP_PASSWORD=replace-with-a-long-owner-password
CMS_BOOTSTRAP_NAME=مالک پنل
