# ─── Site ────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_SITE_URL=https://pesaba.com

# ─── SMTP (CRITICAL: rotate credentials — current creds were exposed in SSR HTML)
# Generate a new password at your mail provider and set it here.
# Never commit real values; this file is .env.example only.
SMTP_HOST=mailservice13.irandns.com
SMTP_PORT=587
SMTP_USER=           # e.g. admin@pesaba.com  ← MUST be set to new value
SMTP_PASS=           # ← MUST be rotated — old value was leaked in page HTML
CONTACT_EMAIL=admin@pesaba.com

# ─── Meilisearch (Phase 1 week 4 — leave blank until deployed)
NUXT_PUBLIC_MEILISEARCH_HOST=
NUXT_PUBLIC_MEILISEARCH_KEY=

# ─── Analytics (Phase 1 — leave blank until Plausible is deployed)
NUXT_PUBLIC_PLAUSIBLE_HOST=
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=pesaba.com
