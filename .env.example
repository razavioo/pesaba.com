# ─── Site ────────────────────────────────────────────────────────────────────
NUXT_PUBLIC_SITE_URL=https://pesaba.com
NUXT_PUBLIC_SITE_INDEXABLE=true
NUXT_PUBLIC_CONTACT_FORM_ENABLED=true
NUXT_PUBLIC_CMS_API_URL=http://localhost:4400/api/v1

# ─── Server-only SMTP ─────────────────────────────────────────────────────────
# Set these on the running Node service, not in a frontend/static build job.
# Rotate the previously exposed mailbox password before production deployment.
NUXT_SMTP_HOST=smtp.example.com
NUXT_SMTP_PORT=587
NUXT_SMTP_SECURE=false
NUXT_SMTP_USER=
NUXT_SMTP_PASS=
NUXT_SMTP_FROM=
NUXT_SMTP_TO=admin@pesaba.com
NUXT_SMTP_SALES_TO=
NUXT_SMTP_SUPPORT_TO=
NUXT_SMTP_PARTNERSHIP_TO=

# ─── Contact API ──────────────────────────────────────────────────────────────
NUXT_CONTACT_ALLOWED_ORIGINS=https://pesaba.com
# Enable only when a trusted reverse proxy strips and sets forwarding headers.
NUXT_CONTACT_TRUST_PROXY=true
NUXT_CONTACT_RATE_LIMIT_MAX=5
NUXT_CONTACT_MAX_BODY_BYTES=16384

# ─── Analytics (Phase 1 — leave blank until Plausible is deployed)
NUXT_PUBLIC_PLAUSIBLE_HOST=
NUXT_PUBLIC_PLAUSIBLE_DOMAIN=pesaba.com
