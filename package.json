{
  "name": "pesaba-com",
  "private": true,
  "type": "module",
  "workspaces": [
    "services/cms-api",
    "modules/cms-contracts"
  ],
  "scripts": {
    "prebuild": "npm run check:secrets && npm run validate:content",
    "build": "npm run build:web && npm run build:cms",
    "build:contracts": "npm --workspace @pesaba/cms-contracts run build",
    "build:web": "nuxt build",
    "build:cms": "npm run build:contracts && npm --workspace @pesaba/cms-api run build",
    "dev": "nuxt dev",
    "dev:cms": "npm --workspace @pesaba/cms-api run dev",
    "cms:generate": "npm --workspace @pesaba/cms-api run prisma:generate",
    "cms:migrate": "npm --workspace @pesaba/cms-api run prisma:migrate",
    "cms:seed": "npm --workspace @pesaba/cms-api run seed",
    "cms:migrate-content-v2": "npm --workspace @pesaba/cms-api run migrate:content-v2 --",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "generate": "nuxt generate",
    "postgenerate": "npm run validate:output",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "migrate": "tsx scripts/migrate.ts",
    "gen:redirects": "tsx scripts/generate-redirects.ts",
    "screenshots": "tsx scripts/take-screenshots.ts",
    "analyze": "nuxt analyze",
    "validate:content": "node --import tsx scripts/validate-content.ts",
    "validate:content-v2": "node --import tsx scripts/validate-content-v2.ts",
    "validate:output": "tsx scripts/validate-output.ts",
    "check:assets": "node --import tsx scripts/validate-content.ts",
    "check:bundle": "node --import tsx scripts/check-bundle.ts",
    "check:secrets": "tsx scripts/check-secrets.ts",
    "optimize:images": "node --import tsx scripts/optimize-images.ts",
    "test": "playwright test"
  },
  "dependencies": {
    "@nuxt/content": "^2.13.4",
    "@nuxt/image": "^1.8.1",
    "@nuxt/ui": "^3.3.2",
    "@nuxtjs/i18n": "^9.5.0",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.2",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2",
    "@tiptap/vue-3": "^2.27.2",
    "@types/markdown-it": "^14.1.2",
    "@vueuse/core": "^12.7.0",
    "@vueuse/nuxt": "^12.7.0",
    "lucide-vue-next": "^0.468.0",
    "markdown-it": "^14.3.0",
    "nodemailer": "9.0.3",
    "nuxt": "3.21.8",
    "sharp": "^0.34.5",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "@nuxt/content": {
      "@nuxtjs/mdc": "0.17.2"
    },
    "sharp": "$sharp"
  },
  "devDependencies": {
    "@nuxt/eslint": "^0.7.4",
    "@playwright/test": "^1.52.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/node": "22.20.1",
    "@types/nodemailer": "7.0.12",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.24.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "4.23.0",
    "typescript": "^5.8.3"
  }
}
